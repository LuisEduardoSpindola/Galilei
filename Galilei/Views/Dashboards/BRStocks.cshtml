@model List<Galilei.Models.Dashboards.AssetData>
@{
    Layout = "_Layout";
}

<style>
    .broker-container {
        padding: 1rem 0;
    }

    .broker-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .widget-panel {
        background: var(--light-card-bg);
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: var(--border-radius-lg, 12px);
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        padding: 1.5rem;
    }

    body.dark-mode .widget-panel {
        background: var(--dark-card-bg, #1e1e1e);
        border-color: rgba(255,255,255,0.05);
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .text-positive { color: #198754; }
    .text-negative { color: #dc3545; }

    .table-broker {
        margin-bottom: 0;
    }

    body.dark-mode .table-broker {
        --bs-table-bg: transparent;
        --bs-table-color: var(--dark-text, #f8f9fa);
        color: var(--dark-text, #f8f9fa);
    }

    .table-broker th {
        font-size: 0.75rem;
        text-transform: uppercase;
        color: var(--light-text);
        opacity: 0.6;
        font-weight: 600;
        border-bottom: 2px solid rgba(0,0,0,0.05);
        padding-bottom: 0.75rem;
    }

    body.dark-mode .table-broker th {
        color: var(--dark-text);
        border-color: rgba(255,255,255,0.05);
    }

    .table-broker td {
        vertical-align: middle;
        padding: 1rem 0.5rem;
        border-bottom: 1px solid rgba(0,0,0,0.03);
        color: var(--light-text);
    }

    body.dark-mode .table-broker td {
        background-color: transparent;
        border-color: rgba(255,255,255,0.02);
        color: var(--dark-text, #f8f9fa);
    }

    .table-broker tr:hover td {
        background-color: rgba(0,0,0,0.01);
    }

    body.dark-mode .table-broker tr:hover td {
        background-color: rgba(255,255,255,0.02);
    }

    .action-btn {
        background: rgba(13, 110, 253, 0.1);
        color: #0d6efd;
        border: none;
        border-radius: 4px;
        padding: 0.4rem 0.8rem;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-block;
        margin-right: 0.5rem;
    }

    .action-btn:hover {
        background: #0d6efd;
        color: white;
    }

    body.dark-mode .action-btn {
        background: rgba(13, 110, 253, 0.15);
        color: #6ea8fe;
    }

    body.dark-mode .action-btn:hover {
        background: #0d6efd;
        color: white;
    }
</style>

<div class="broker-container">
    <div class="broker-header animated fade-in-up">
        <div>
            <h2 class="mb-0 fw-bold"><i class="bi bi-list-columns"></i> @ViewData["Title"]</h2>
            <p class="text-muted small mb-0 mt-1">Exibindo resultados das principais ações negociadas na B3</p>
        </div>
        <div>
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0" id="searchInput" placeholder="Buscar ação...">
            </div>
        </div>
    </div>

    <div class="widget-panel animated fade-in-up" style="animation-delay: 0.1s;">
        <div class="table-responsive">
            <table class="table table-borderless table-broker w-100 m-0" id="stocksTable">
                <thead>
                    <tr>
                        <th>Ativo</th>
                        <th>Empresa</th>
                        <th>Último Preço (R$)</th>
                        <th>Variação 24h</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var asset in Model ?? new List<Galilei.Models.Dashboards.AssetData>())
                    {
                        var isPositive = asset.ChangePercentage24h >= 0;
                        <tr>
                            <td>
                                <div class="fw-bold" style="color: var(--primary-color);">@asset.Symbol</div>
                            </td>
                            <td>
                                <div>@asset.Name</div>
                            </td>
                            <td class="fw-bold">@asset.Price.ToString("N2")</td>
                            <td class="fw-bold @(isPositive ? "text-positive" : "text-negative")">
                                @(isPositive ? "+" : "")@asset.ChangePercentage24h.ToString("N2")%
                            </td>
                            <td class="text-end">
                                <a href="https://www.google.com/search?q=cotação+@asset.Symbol" target="_blank" class="action-btn">
                                    <i class="bi bi-box-arrow-up-right"></i> Detalhes
                                </a>
                                <a href="/Portfolio/AddAsset?ticker=@asset.Symbol&price=@asset.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)" class="btn btn-sm btn-outline-success">
                                    <i class="bi bi-plus-lg"></i> Comprar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function() {
            var value = this.value.toLowerCase().trim();
            var rows = document.querySelectorAll('#stocksTable tbody tr');

            rows.forEach(function(row) {
                var symbol = row.cells[0].textContent.toLowerCase();
                var name = row.cells[1].textContent.toLowerCase();

                if (symbol.includes(value) || name.includes(value)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}