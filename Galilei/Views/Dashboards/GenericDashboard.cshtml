@model List<Galilei.Models.Dashboards.AssetData>

<style>
    .dashboard-container {
        padding: 2rem 0;
    }
    .db-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }
    .db-title {
        font-weight: 700;
        margin: 0;
    }
    .db-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
    }
    .db-card {
        background: var(--light-card-bg);
        border-radius: var(--border-radius);
        padding: 1.5rem;
        box-shadow: var(--shadow);
        transition: transform 0.2s;
    }
    body.dark-mode .db-card {
        background: var(--dark-card-bg);
        box-shadow: var(--shadow-dark);
    }
    .db-card:hover {
        transform: translateY(-5px);
    }
    .asset-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }
    .asset-symbol {
        font-weight: 800;
        font-size: 1.2rem;
    }
    .asset-name {
        font-size: 0.9rem;
        opacity: 0.7;
    }
    .asset-price {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    .asset-change {
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .change-positive { color: #2ecc71; }
    .change-negative { color: #e74c3c; }
    
    .db-chart-container {
        background: var(--light-card-bg);
        border-radius: var(--border-radius);
        padding: 1.5rem;
        box-shadow: var(--shadow);
        margin-top: 2rem;
        height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: var(--light-text);
        opacity: 0.6;
        border: 2px dashed var(--light-border);
    }
    body.dark-mode .db-chart-container {
        background: var(--dark-card-bg);
        box-shadow: var(--shadow-dark);
        color: var(--dark-text);
        border-color: var(--dark-border);
    }
</style>

<div class="container dashboard-container">
    <div class="db-header animated fade-in-up">
        <h2 class="db-title">@ViewData["Title"]</h2>
        <div class="db-actions">
            @* Could add filters or refresh buttons here *@
            <button class="btn btn-outline-primary btn-sm" onclick="location.reload()">Atualizar Dados</button>
        </div>
    </div>

    <div class="db-grid animated fade-in-up" style="animation-delay: 0.1s;">
        @if(Model != null && Model.Any())
        {
            foreach(var asset in Model)
            {
                <div class="db-card">
                    <div class="asset-header">
                        <div>
                            <div class="asset-symbol">@asset.Symbol</div>
                            <div class="asset-name">@asset.Name</div>
                        </div>
                    </div>
                    <div class="asset-price">
                        R$ @asset.Price.ToString("N2")
                    </div>
                    <div class="asset-change @(asset.ChangePercentage24h >= 0 ? "change-positive" : "change-negative")">
                        @if(asset.ChangePercentage24h >= 0)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>
                            <span>+@asset.ChangePercentage24h.ToString("N2")%</span>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"></polyline><polyline points="16 17 22 17 22 11"></polyline></svg>
                            <span>@asset.ChangePercentage24h.ToString("N2")%</span>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-warning w-100">Não foi possível carregar os dados no momento. Tente novamente mais tarde.</div>
        }
    </div>

    <div class="db-chart-container animated fade-in-up" style="animation-delay: 0.2s;">
        <div>
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-3"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
            <p class="mb-0">Gráfico Avançado (TradingView/Similar) será renderizado aqui.</p>
        </div>
    </div>
</div>
