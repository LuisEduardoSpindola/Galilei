@model List<Galilei.Models.Market.PlatformRecommendation>
@{
    ViewData["Title"] = "Melhores Plataformas";
}

<style>
    .platforms-container {
        padding: 2rem 0;
    }
    .platform-card {
        background: var(--light-card-bg);
        border-radius: var(--border-radius);
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: transform 0.2s;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
    }
    body.dark-mode .platform-card {
        background: var(--dark-card-bg);
        box-shadow: var(--shadow-dark);
    }
    .platform-card:hover {
        transform: translateY(-5px);
    }
    .platform-img {
        width: 300px;
        height: 100%;
        min-height: 250px;
        object-fit: cover;
    }
    .platform-content {
        padding: 2rem;
        flex-grow: 1;
    }
    .platform-badge {
        background: rgba(255, 140, 0, 0.1);
        color: var(--primary-color);
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
        display: inline-block;
        margin-bottom: 1rem;
    }
    .platform-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    .platform-rating {
        font-size: 0.9rem;
        color: #f1c40f;
        margin-bottom: 1rem;
        font-weight: 600;
    }
    .platform-desc {
        opacity: 0.8;
        margin-bottom: 1.5rem;
    }
    .platform-btn {
        background-color: var(--primary-color);
        color: white;
        text-decoration: none;
        padding: 10px 24px;
        border-radius: var(--border-radius);
        font-weight: 600;
        transition: opacity 0.2s;
        display: inline-block;
    }
    .platform-btn:hover {
        opacity: 0.9;
        color: white;
    }

    @@media (max-width: 768px) {
        .platform-card {
            flex-direction: column;
        }
        .platform-img {
            width: 100%;
            height: 200px;
            min-height: auto;
        }
    }
</style>

<div class="container platforms-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight: 700;">Recomendação de Plataformas</h2>
    </div>

    <div class="animated fade-in-up">
        @if(Model != null && Model.Any())
        {
            foreach(var platform in Model)
            {
                <div class="platform-card">
                    <img src="@platform.ImageUrl" alt="@platform.Name" class="platform-img" />
                    <div class="platform-content">
                        <span class="platform-badge">@platform.Category</span>
                        <h3 class="platform-title">@platform.Name</h3>
                        <div class="platform-rating">★ @platform.Rating</div>
                        <p class="platform-desc">@platform.Description</p>
                        <a href="@platform.Link" class="platform-btn" target="_blank">Acessar Plataforma</a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">Nenhuma plataforma recomendada no momento.</div>
        }
    </div>
</div>
