@model Galilei.Models.Portfolio.PortfolioViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-container {
        padding: 2rem 0;
    }
    
    .welcome-header {



        margin-bottom: 2rem;
    }
    
    .welcome-header h1 {
        font-weight: 700;
        color: var(--light-text);
    }
    
    body.dark-mode .welcome-header h1 {
        color: var(--dark-text);
    }
    
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
    }
    
    .stat-card {
        background: var(--light-card-bg);
        border-radius: var(--border-radius);
        padding: 1.5rem;
        box-shadow: var(--shadow);
        transition: transform 0.2s;
    }
    
    body.dark-mode .stat-card {
        background: var(--dark-card-bg);
        box-shadow: var(--shadow-dark);
    }
    
    .stat-card:hover {
        transform: translateY(-5px);
    }
    
    .stat-label {
        font-size: 0.9rem;
        color: var(--light-text);
        opacity: 0.7;
        margin-bottom: 0.5rem;
    }
    
    body.dark-mode .stat-label {
        color: var(--dark-text);
    }
    
    .stat-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--primary-color);
    }
    
    .dashboard-visual {
        background: var(--light-card-bg);
        border-radius: var(--border-radius);
        padding: 2rem;
        box-shadow: var(--shadow);
        height: 400px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        margin-bottom: 2rem;
    }
    
    body.dark-mode .dashboard-visual {
        background: var(--dark-card-bg);
        box-shadow: var(--shadow-dark);
    }
    
    .chart-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--light-text);
        opacity: 0.5;
        border: 2px dashed var(--light-border);
        border-radius: 8px;
    }
    
    body.dark-mode .chart-placeholder {
        color: var(--dark-text);
        border-color: var(--dark-border);
    }

</style>

<div class="dashboard-container">
    <div class="welcome-header animated fade-in-up">
        <h1>Olá, @User.Identity.Name!</h1>
        <p>Bem-vindo ao seu painel com base na sua carteira da B3.</p>
    </div>

    <div class="stats-grid animated fade-in-up" style="animation-delay: 0.1s;">
        <div class="stat-card">
            <div class="stat-label">Total Investido</div>
            <div class="stat-value">R$ @Model.TotalInvested.ToString("N2")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Saldo Atual</div>
            <div class="stat-value">R$ @Model.CurrentBalance.ToString("N2")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Lucro / Prejuízo</div>
            <div class="stat-value">R$ @Model.TotalProfitLoss.ToString("N2")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Ativos na Carteira</div>
            <div class="stat-value">@Model.AssetsCount</div>
        </div>
    </div>

    <div class="dashboard-visual animated fade-in-up" style="animation-delay: 0.2s;">
        <h3 style="margin-bottom: 1rem; align-self: flex-start; var(--light-text);">Resumo dos Ativos</h3>
        <div class="chart-placeholder">
            @if (Model.Assets.Any())
            {
                <div class="table-responsive w-100">
                    <table class="table table-borderless align-middle mb-0">
                        <thead>
                            <tr style="opacity: 0.7;">
                                <th>Ativo</th>
                                <th>Preço Atual</th>
                                <th>Preço Desejado</th>
                                <th>Direção</th>
                                <th>Alerta</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var asset in Model.Assets.Take(5))
                            {
                                <tr>
                                    <td>@asset.Ticker</td>
                                    <td>R$ @asset.CurrentPrice.ToString("N2")</td>
                                    <td>R$ @asset.DesiredPrice.ToString("N2")</td>
                                    <td>@asset.DesiredPriceType</td>
                                    <td>@(asset.IsTargetNotified ? "Enviado" : "Aguardando")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p>Você ainda não cadastrou ativos. Adicione o primeiro na sua carteira.</p>
            }
        </div>
    </div>
</div>
