@{
    ViewData["Title"] = "Crie sua Conta";
}

<style>
    /* Fixed Layout to prevent scrolling */
    .auth-container {
        position: fixed;
        top: 80px; /* Below navbar */
        left: 0;
        width: 100%;
        height: calc(100vh - 80px);
        display: flex;
        overflow: hidden;
        background-color: var(--light-bg);
        z-index: 50; /* Ensure it stays above footer/main padding */
    }

    body.dark-mode .auth-container {
        background-color: var(--dark-bg);
    }

    /* Left Side: Visual */
    .auth-visual {
        flex: 1.2;
        background: linear-gradient(135deg, #FF8C00 0%, #FF5F00 100%);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 4rem;
        color: white;
        position: relative;
        overflow: hidden;
    }

    .auth-visual::before {
        content: '';
        position: absolute;
        width: 150%;
        height: 150%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 70%);
        top: -25%;
        left: -25%;
    }

    .auth-content {
        z-index: 2;
        text-align: center;
        max-width: 500px;
        margin-bottom: 2rem;
    }

    .auth-visual h2 {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        line-height: 1.1;
        text-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .auth-visual p {
        font-size: 1.1rem;
        opacity: 0.95;
    }

    /* Right Side: Form */
    .auth-form-side {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center; /* Center vertically */
        align-items: center;     /* Center horizontally */
        padding: 2rem;
        background: transparent;
        overflow-y: auto; /* Allow scroll only inside form if needed */
    }

    .form-wrapper {
         width: 100%;
         max-width: 420px;
         background: transparent;
         display: flex;
         flex-direction: column;
         justify-content: center;
         animation: fade-in-right 0.6s ease-out;
    }

    @@keyframes fade-in-right {
        from { opacity: 0; transform: translateX(20px); }
        to { opacity: 1; transform: translateX(0); }
    }

    .auth-subtitle {
        margin-bottom: 2rem;
        color: var(--light-text);
        font-size: 0.95rem;
        opacity: 0.7;
    }

    body.dark-mode .auth-subtitle {
        color: var(--dark-text);
    }

    .form-header-mobile {
        display: none;
        text-align: center;
        margin-bottom: 1.5rem;
    }

    /* Floating Labels & Inputs */
    .form-floating {
        position: relative;
        margin-bottom: 1rem;
    }

    .form-floating input {
        width: 100%;
        padding: 1rem 0.75rem;
        padding-top: 1.625rem;
        padding-bottom: 0.625rem;
        font-size: 0.95rem;
        background-color: rgba(0,0,0,0.03); /* Subtle background */
        border: 1px solid transparent; /* No border initially */
        border-bottom: 2px solid var(--light-border);
        border-radius: 8px 8px 0 0;
        color: inherit; /* Inherit from body */
        transition: all 0.2s ease;
        height: 52px;
    }

    body.dark-mode .form-floating input {
        background-color: rgba(255,255,255,0.05);
        border-bottom-color: var(--dark-border);
    }

    .form-floating input:focus {
        background-color: rgba(0,0,0,0.05); /* Slightly darker on focus */
        border-bottom-color: var(--primary-color);
        outline: none;
        box-shadow: none; /* No shadow */
    }

    body.dark-mode .form-floating input:focus {
        background-color: rgba(255,255,255,0.08);
    }

    .form-floating label {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        padding: 1rem 0.75rem;
        pointer-events: none;
        border: 1px solid transparent;
        transform-origin: 0 0;
        transition: opacity .1s ease-in-out, transform .1s ease-in-out;
        color: #777; /* Neutral label color */
        display: flex;
        align-items: center;
    }

    body.dark-mode .form-floating label {
        color: #aaa;
    }

    .form-floating input:focus ~ label,
    .form-floating input:not(:placeholder-shown) ~ label {
        opacity: .7;
        transform: scale(.8) translateY(-0.65rem) translateX(0.15rem);
        height: auto;
    }

    /* Password Toggle */
    .password-wrapper {
        position: relative;
    }

    .password-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px; /* Larger hit area */
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        color: inherit;
        opacity: 0.5;
        transition: all 0.2s;
    }

    .password-toggle:hover, .password-toggle.active {
        opacity: 1;
        color: var(--primary-color);
    }

    .form-btn {
        margin-top: 10px;
    }

    /* Bar Chart Animation */
    .bar-chart {
        width: 100%;
        max-width: 400px;
        height: 200px;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 10px;
        z-index: 2;
    }

    .bar {
        flex: 1;
        background: rgba(255,255,255,0.3);
        border-radius: 4px 4px 0 0;
        position: relative;
        transform-origin: bottom;
        animation: grow-up 1s ease-out forwards;
        box-shadow: 0 0 10px rgba(255,255,255,0.1);
    }

    .bar:hover {
        background: rgba(255,255,255,0.5);
    }

    .bar::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: white;
        border-radius: 4px 4px 0 0;
        box-shadow: 0 0 8px rgba(255,255,255,0.5);
    }

    @@keyframes grow-up {
        from { transform: scaleY(0); }
        to { transform: scaleY(1); }
    }


    /* Responsive */
    @@media (max-width: 992px) {
        .auth-container {
            position: relative; /* Revert to relative for scrolling on mobile */
            top: 0;
            height: auto;
            flex-direction: column;
            overflow: visible;
        }
        .auth-visual {
            display: none;
        }
        .form-header-mobile {
            display: block;
        }
        .auth-form-side {
            padding: 3rem 1.5rem;
            min-height: calc(100vh - 80px); /* Full height on mobile */
        }
        .form-wrapper {
            justify-content: flex-start;
        }
    }
</style>

<div class="auth-container">
    <!-- Left side: Visual with Bar Chart -->
    <div class="auth-visual">
        <div class="auth-content animated fade-in-up" style="animation-duration: 0.8s;">
            <h2>Evolução Constante</h2>
            <p>Acompanhe o crescimento do seu patrimônio com ferramentas exclusivas.</p>
        </div>

        <div class="bar-chart">
            <div class="bar" style="height: 30%; animation-delay: 0.2s;"></div>
            <div class="bar" style="height: 45%; animation-delay: 0.3s;"></div>
            <div class="bar" style="height: 40%; animation-delay: 0.4s;"></div>
            <div class="bar" style="height: 60%; animation-delay: 0.5s;"></div>
            <div class="bar" style="height: 55%; animation-delay: 0.6s;"></div>
            <div class="bar" style="height: 75%; animation-delay: 0.7s;"></div>
            <div class="bar" style="height: 90%; animation-delay: 0.8s;"></div>
        </div>
    </div>

    <!-- Right side: Form -->
    <div class="auth-form-side">
        <div class="form-wrapper">
            <div class="form-header-mobile">
                <h2>Galilei</h2>
                <p>Crie sua conta</p>
            </div>

            <h3 style="margin-bottom: 0.5rem; font-weight: 700; color: var(--primary-color);" class="d-none d-lg-block">Criar Conta</h3>
            <p class="auth-subtitle d-none d-lg-block">Preencha seus dados para começar.</p>

            <form id="register-form" novalidate>
                <div class="form-group form-floating">
                    <input type="text" id="fullName" name="fullName" class="form-control" placeholder="Nome Completo" required>
                    <label for="fullName">Nome Completo</label>
                    <div class="invalid-feedback">O nome completo é obrigatório.</div>
                </div>

                <div class="row g-2">
                    <div class="col-6">
                        <div class="form-group form-floating">
                            <input type="text" id="cpf" name="cpf" class="form-control" placeholder="CPF" required pattern="\d{3}\.\d{3}\.\d{3}-\d{2}">
                            <label for="cpf">CPF</label>
                            <div class="invalid-feedback">CPF inválido.</div>
                        </div>
                    </div>
                    <div class="col-6">
                         <div class="form-group form-floating">
                            <input type="tel" id="phone" name="phone" class="form-control" placeholder="Telefone" required>
                            <label for="phone">Telefone</label>
                            <div class="invalid-feedback">Telefone inválido.</div>
                        </div>
                    </div>
                </div>

                <div class="form-group form-floating">
                    <input type="email" id="email" name="email" class="form-control" placeholder="Email" required>
                    <label for="email">Email</label>
                    <div class="invalid-feedback">Por favor, insira um email válido.</div>
                </div>

                <div class="form-group form-floating password-wrapper">
                    <input type="password" id="password" name="password" class="form-control" placeholder="Senha" required minlength="8">
                    <label for="password">Senha</label>
                    <button type="button" class="password-toggle" onclick="togglePassword('password', this)" tabindex="-1" title="Ver senha">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-open"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-closed" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                    </button>
                    <div class="invalid-feedback">Mínimo de 8 caracteres.</div>
                </div>

                <div class="form-group form-floating password-wrapper">
                    <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="Confirmar Senha" required>
                    <label for="confirmPassword">Confirmar Senha</label>
                    <button type="button" class="password-toggle" onclick="togglePassword('confirmPassword', this)" tabindex="-1" title="Ver senha">
                         <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-open"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                         <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-closed" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                    </button>
                    <div class="invalid-feedback" id="confirmPassword-feedback">As senhas não coincidem.</div>
                </div>

                <button type="submit" class="form-btn">Criar Conta</button>
            </form>
            <div class="form-footer mt-4 text-center">
                <p style="margin: 0; padding: 0;">Já tem uma conta? <a asp-action="Login" style="font-weight: 700;">Faça Login</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Toggle Password Visibility
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const eyeOpen = btn.querySelector('.eye-open');
            const eyeClosed = btn.querySelector('.eye-closed');

            if (input.type === "password") {
                input.type = "text";
                eyeOpen.style.display = 'none';
                eyeClosed.style.display = 'block';
                btn.classList.add('active');
            } else {
                input.type = "password";
                eyeOpen.style.display = 'block';
                eyeClosed.style.display = 'none';
                btn.classList.remove('active');
            }
        }

        // Basic CPF and Phone masking
        const cpfInput = document.getElementById('cpf');
        const phoneInput = document.getElementById('phone');

        cpfInput.addEventListener('input', (e) => {
            let value = e.target.value.replace(/\D/g, '');
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
            e.target.value = value;
        });

        phoneInput.addEventListener('input', (e) => {
            let value = e.target.value.replace(/\D/g, '');
            value = value.replace(/^(\d{2})(\d)/g, '($1) $2');
            value = value.replace(/(\d{5})(\d)/, '$1-$2');
            e.target.value = value;
        });

        // Frontend validation logic
        const form = document.getElementById('register-form');
        const password = document.getElementById('password');
        const confirmPassword = document.getElementById('confirmPassword');
        const confirmPasswordFeedback = document.getElementById('confirmPassword-feedback');

        form.addEventListener('submit', function (event) {
            let passwordsMatch = password.value === confirmPassword.value;

            if (!passwordsMatch) {
                confirmPassword.setCustomValidity('Invalid');
                confirmPasswordFeedback.style.display = 'block';
            } else {
                confirmPassword.setCustomValidity('');
                confirmPasswordFeedback.style.display = 'none';
            }

            if (!form.checkValidity()) {
                event.preventDefault();
                event.stopPropagation();
            }

            form.classList.add('was-validated');
        }, false);

        // Real-time password confirmation check
        confirmPassword.addEventListener('input', () => {
            if (password.value !== confirmPassword.value) {
                confirmPassword.setCustomValidity('Invalid');
                 if(form.classList.contains('was-validated')) {
                    confirmPasswordFeedback.style.display = 'block';
                }
            } else {
                confirmPassword.setCustomValidity('');
                confirmPasswordFeedback.style.display = 'none';
            }
        });
    </script>
}

