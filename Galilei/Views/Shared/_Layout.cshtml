<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Galilei</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Galilei.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="app-nav container">
            <a class="app-brand" asp-area="" asp-controller="Home" asp-action="Index">Galilei</a>
            <div class="nav-actions d-flex align-items-center gap-3">
                @if (User.Identity.IsAuthenticated)
                {
                    <a class="nav-link" asp-area="" asp-controller="Portfolio" asp-action="Index">Minha Carteira</a>
                    <a class="nav-link" asp-area="" asp-controller="Market" asp-action="News">Notícias</a>
                    <div class="dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" id="dashboardsDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            Dashboards
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dashboardsDropdown">
                            <li><a class="dropdown-item" asp-controller="Dashboards" asp-action="BRStocks">Ações B3</a></li>
                            <li><a class="dropdown-item" asp-controller="Dashboards" asp-action="FixedIncome">Renda Fixa</a></li>
                        </ul>
                    </div>
                    <span class="nav-link" style="opacity: 0.7; font-size: 0.9rem;">Olá, @User.Identity.Name</span>
                    <a class="nav-link cta" asp-area="" asp-controller="Account" asp-action="Logout">Sair</a>
                }
                else
                {
                    <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="nav-link cta" asp-area="" asp-controller="Account" asp-action="Register">Cadastrar</a>
                }
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const themeSwitcher = document.getElementById('theme-switcher');
        const body = document.body;

        // Empty script where dark mode logic used to be
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
